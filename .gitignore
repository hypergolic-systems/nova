# .NET / dotnet
mod/**/build/
mod/**/bin/
mod/**/obj/

# Generated proto bindings (regenerated by `just proto`)
mod/Nova.Core/Persistence/Protos/Generated/

# Vendored Dragonglass DLLs (regenerated by `just sync-dragonglass-stubs`)
stubs/dragonglass/*.dll
stubs/dragonglass/*.pdb

# Nova UI workspace
ui/external/
ui/node_modules/
ui/**/node_modules/
ui/**/dist/
ui/**/.vite/
ui/**/tsconfig.tsbuildinfo

# Rust
target/
**/*.rs.bk

# macOS
.DS_Store

# Claude — per-developer config (settings, history) stays ignored,
# but `.claude/skills/` is part of the repo so CLAUDE.md can point at
# project-shared skill files. (Listing `.claude/*` rather than
# `.claude/` so the `!skills/` re-include works — git's gitignore
# logic short-circuits descent into a flatly-ignored directory.)
.claude/*
!.claude/skills/
!.claude/skills/**

# Release staging
release/

# Logs
*.log

